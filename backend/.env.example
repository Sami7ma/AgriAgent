# Environment Configuration Template
# Copy this file to .env and fill in your values
# SECURITY: Never commit .env to version control

# ============================================
# API KEYS (REQUIRED)
# ============================================
# Google Gemini API Key - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Comma-separated list of valid API keys for production
# Example: key1,key2,key3
VALID_API_KEYS=

# ============================================
# SERVER CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated)
# Development: http://localhost:3000,http://127.0.0.1:8000,http://10.0.2.2:8000
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000,http://10.0.2.2:8000

# Server host and port
HOST=0.0.0.0
PORT=8000

# Environment mode (development/production)
# WARNING: Always use 'production' for deployed instances
ENVIRONMENT=development

# ============================================
# RATE LIMITING
# ============================================
# Maximum requests per time window
RATE_LIMIT_REQUESTS=100

# Time window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================
# Market data API key (for real market prices)
# Get from: https://www.worldbank.org/en/data
MARKET_API_KEY=

# News API key (for agricultural news)
# Get from: https://newsapi.org
NEWS_API_KEY=

# ============================================
# DATABASE (Future)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost/agriagent_db

# ============================================
# MONITORING (Future)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN=

